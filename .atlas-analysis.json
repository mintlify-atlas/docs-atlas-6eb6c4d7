  "keyFeatures": [
    "Group trip discovery and enrollment",
    "Role-based access control (Viatger, Creador, Admin)",
    "Real-time trip chat per journey",
    "Trip creation and management for Creators and Admins",
    "Creator promotion request workflow",
    "JWT-based authentication",
    "User profile management"
  ],
  "publicApiSurface": [
    "POST /auth/login",
    "POST /auth/register",
    "GET /viatge/trips",
    "GET /viatge/trips/{id}",
    "POST /viatge/trips/{id}/enroll",
    "POST /viatge/trips/{id}/leave",
    "POST /viatge/promote-request",
    "POST /creadorViatges/trips",
    "PUT /creadorViatges/trips/{id}",
    "GET /missatges/trips/{trip_id}/chat",
    "POST /missatges/trips/{trip_id}/chat/send",
    "GET /users/me",
    "PUT /users/me/{nom}/{bio}",
    "GET /admin/users",
    "PUT /admin/users/{user_id}/promote",
    "GET /admin/users/promotions",
    "PUT /admin/promotions/{user_id}"
  ]
